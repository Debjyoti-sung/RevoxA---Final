# App Config
NEXT_PUBLIC_APP_NAME=Memora AI
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENV=development

# Internal FastAPI Backend URL
BACKEND_URL=http://127.0.0.1:8000

# Authentication (Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# AI Providers
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_AI_API_KEY=your-google-ai-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# Memory System (Hindsight)
HINDSIGHT_API_KEY=hsk_726b5ef18bf9d71498c570c9517b140e_7189e813d8984847
HINDSIGHT_BASE_URL=https://api.hindsight.vectorize.io

# Vector Database (Qdrant)
QDRANT_URL=https://your-qdrant-cluster.qdrant.tech
QDRANT_API_KEY=your-qdrant-api-key

# Database (Postgres)
DATABASE_URL=postgresql://postgres:password@localhost:5432/memora
DIRECT_URL=postgresql://postgres:password@localhost:5432/memora

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key

# OAuth logins
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Monitoring
SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/project
POSTHOG_API_KEY=phc_your_posthog_api_key

# Storage
SUPABASE_STORAGE_BUCKET=memora-uploads
